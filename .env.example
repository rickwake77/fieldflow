# FieldFlow Environment Configuration
# Copy this to .env and fill in your values

# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@your-rds-endpoint.eu-west-2.rds.amazonaws.com:5432/fieldflow?schema=public"

# ── Auth ─────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-string-here"
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ── Email / Magic Links (optional — links logged to console if not set) ──
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="FieldFlow <noreply@fieldflow.app>"
